{
  "name": "convivium-frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "start": "vite preview --host 0.0.0.0 --port ${PORT:-4173}",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "pinia": "^3.0.4",
    "axios": "^1.13.6",
    "@vueuse/core": "^14.2.1",
    "@stripe/stripe-js": "^8.9.0",
    "chart.js": "^4.4.7",
    "vue-chartjs": "^5.3.2",
    "dayjs": "^1.11.13"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^28.1.0",
    "vitest": "^4.0.18",
    "@vitejs/plugin-vue": "^6.0.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.5",
    "tailwindcss": "^4.2.1",
    "postcss": "^8.5.8",
    "autoprefixer": "^10.4.27",
    "@types/node": "^25.3.3"
  }
}
